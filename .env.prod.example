# =====================================================================
# JetKVM Cloud — Production environment template
#
# Скопируйте в .env.prod и заполните реальные значения:
#   cp .env.prod.example .env.prod
#
# Сгенерируйте секреты:
#   openssl rand -hex 16   # DB_PASSWORD
#   openssl rand -hex 32   # COOKIE_SECRET, JWT_SECRET, TURN_SECRET
#
# В Portainer эти переменные можно задать в разделе "Environment variables"
# при создании стека — они переопределят значения из этого файла.
# =====================================================================

# Доменное имя (DNS A-запись должна указывать на PUBLIC_IP)
DOMAIN=kvm.example.com

# Полные URL (https:// обязательно, должны совпадать с DOMAIN)
API_HOSTNAME=https://kvm.example.com
APP_HOSTNAME=https://kvm.example.com

# Базовые параметры (не менять)
NODE_ENV=production
PORT=3000

# === Секреты (ОБЯЗАТЕЛЬНО заменить!) ===
DB_PASSWORD=CHANGE_ME_openssl_rand_hex_16
DATABASE_URL=postgresql://jetkvm:CHANGE_ME_openssl_rand_hex_16@db:5432/jetkvm?schema=public
COOKIE_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
TURN_SECRET=CHANGE_ME_openssl_rand_hex_32

# === TURN / WebRTC ===
TURN_HOST=203.0.113.10
TURN_PORT=3478
ICE_SERVERS=stun:stun.l.google.com:19302

# === CORS / Proxy ===
CORS_ORIGINS=https://kvm.example.com
REAL_IP_HEADER=X-Forwarded-For

# === Ограничение регистрации (опционально) ===
# Если задано — регистрироваться могут только перечисленные email,
# через запятую. Пусто = открытая регистрация.
ALLOWED_IDENTITIES=

# === R2 / S3 для релизов прошивок (опционально) ===
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_CDN_URL=
